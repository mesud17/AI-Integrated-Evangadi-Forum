# # Server
# PORT=5004
# FRONTEND_URL=http://localhost:5000

# # Database
# DB_HOST=localhost
# DB_USER=root
# DB_PASSWORD=
# # DB_PASS is also supported as a local-dev alias.
# DB_NAME=evangadi_forum

# # JWT — required, no default (server will refuse to start without this)
# JWT_SECRET=your_jwt_secret_here
# JWT_EXPIRES_IN=1d

# # AI (Gemini)
# GEMINI_API_KEY=your_gemini_api_key_here
# RAG_EMBEDDING_DIM is the dimensionality for RAG document & query embeddings.
# Default 768 (matches question embeddings). Query and chunk vectors MUST use the
# same value — if you change it, re-run: node scripts/reembed-rag-chunks.js
# RAG_EMBEDDING_DIM=768
